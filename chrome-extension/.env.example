# Chrome Extension — environment template
# Copy to `.env` and fill in. NEVER commit the real .env.
#
# Backend is "decide later" — fill the block that matches your chosen sync layer.

# ── Bitwarden cloud (default path) ────────────────────────────────────────
BW_CLIENTID=
BW_CLIENTSECRET=
BW_EMAIL=
# Master password is entered in the UI at unlock time — it is NEVER stored here.

# ── Vaultwarden self-host (optional) ──────────────────────────────────────
# Point both apps at your own server instead of bitwarden.com.
# BW_SERVER=http://your-server-ip:8080
