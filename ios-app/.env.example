# iPhone App — environment template
# Copy to `.env` and fill in. NEVER commit the real .env.
# On-device, these values are read from the iOS Keychain, not from a plain file.

# ── Bitwarden cloud (default path) ────────────────────────────────────────
BW_CLIENTID=
BW_CLIENTSECRET=
BW_EMAIL=
# Master password is entered via Face ID / manual entry — NEVER stored here.

# ── Vaultwarden self-host (optional) ──────────────────────────────────────
# BW_SERVER=http://your-server-ip:8080

# ── Tailscale VPN (Phase 4) ───────────────────────────────────────────────
# Auth key is stored in the iOS Keychain (key name: tailscale-auth-key), not here.
# TS_AUTH_KEY=
# TS_API_TOKEN=
